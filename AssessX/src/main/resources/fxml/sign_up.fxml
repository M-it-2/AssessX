<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.assessx.assessx.controller.SignUpController"
           styleClass="login-root">

    <VBox styleClass="login-card"
          maxWidth="480"
          minWidth="400"
          alignment="CENTER"
          StackPane.alignment="CENTER">
        <padding>
            <Insets bottom="48" left="56" right="56" top="48"/>
        </padding>

        <Label text="AssessX" styleClass="login-brand"/>
        <Label text="Create your account" styleClass="login-title"/>

        <VBox spacing="12" style="-fx-padding: 24 0 0 0;">

            <VBox spacing="4">
                <Label text="First name" styleClass="field-label"/>
                <TextField fx:id="firstNameField" promptText="Андрiй" styleClass="input-field"/>
                <Label fx:id="firstNameError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Last name" styleClass="field-label"/>
                <TextField fx:id="lastNameField" promptText="Шевченко" styleClass="input-field"/>
                <Label fx:id="lastNameError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Group number" styleClass="field-label"/>
                <TextField fx:id="groupField" promptText="123" styleClass="input-field"/>
                <Label fx:id="groupError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField" promptText="user@gmail.com" styleClass="input-field"/>
                <Label fx:id="emailError" styleClass="field-error" visible="false" managed="false"/>
            </VBox>

        </VBox>

        <VBox spacing="4" style="-fx-padding: 16 0 0 0;">
            <Button text="Create account" onAction="#onSignUpClick"
                    styleClass="btn-register" maxWidth="Infinity"
                    style="-fx-padding: 12 24; -fx-font-size: 16px; -fx-pref-height: 48;"/>
        </VBox>

        <Label text="Already have an account? Sign in"
               onMouseClicked="#onSignInClick"
               styleClass="link-label"
               style="-fx-padding: 16 0 0 0;"/>

    </VBox>
</StackPane>
